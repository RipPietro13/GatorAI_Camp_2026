            "    (1): Linear(in_features=128, out_features=128, bias=True)\n",
            "    (2): ReLU()\n",
            "    (3): Dropout(p=0.3, inplace=False)\n",
            "    (4): Linear(in_features=128, out_features=6, bias=True)\n",
            "  )\n",
