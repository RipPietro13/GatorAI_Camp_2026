   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Dataset class and transforms defined!\n",
      "🎨 Training uses data augmentation for better generalization\n",
      "📏 Validation uses clean transforms for accurate evaluation\n"
     ]
