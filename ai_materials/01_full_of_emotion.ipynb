    "                    fontsize=12,\n",
    "                    fontweight=\"bold\",\n",
    "                )\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    print(\"🔍 Green = Correct Prediction, Red = Incorrect Prediction\")\n",
